  :effect (and (holding ?obj) (not (clear ?obj)) (not (ontable ?obj)) (not (handempty)) (when (and (ontable black_block_2) (not (= ?obj black_block_2))) (hold_0)) (when (or (not (and (ontable white_block_2) (not (= ?obj white_block_2)))) (not (and (clear red_block_1) (not (= ?obj red_block_1))))) (seen_psi_1)) (when (not (and (clear red_block_1) (not (= ?obj red_block_1)))) (hold_2)) (when (not (and (clear white_block_1) (not (= ?obj white_block_1)))) (hold_3)) (when (or (and (ontable red_block_1) (not (= ?obj red_block_1))) (on black_block_1 red_block_1)) (hold_4)) (when (not (and (clear white_block_2) (not (= ?obj white_block_2)))) (hold_5)) (when (and (not (and (clear white_block_2) (not (= ?obj white_block_2)))) (not (or (not (and (clear black_block_2) (not (= ?obj black_block_2)))) (= ?obj white_block_1) (holding white_block_1)))) (not (hold_6))) (when (or (not (and (clear black_block_2) (not (= ?obj black_block_2)))) (= ?obj white_block_1) (holding white_block_1)) (hold_6)) (increase (total-cost) 1)))
 (:action putdown
