  :precondition (and (holding ?obj) (or (not (or (= ?obj black_block_2) (ontable black_block_2))) (seen_psi_1)))
  :effect (and (clear ?obj) (handempty) (ontable ?obj) (not (holding ?obj)) (when (or (= ?obj black_block_2) (ontable black_block_2)) (hold_0)) (when (or (not (or (= ?obj white_block_2) (ontable white_block_2))) (not (or (= ?obj red_block_1) (clear red_block_1)))) (seen_psi_1)) (when (not (or (= ?obj red_block_1) (clear red_block_1))) (hold_2)) (when (not (or (= ?obj white_block_1) (clear white_block_1))) (hold_3)) (when (or (= ?obj red_block_1) (ontable red_block_1) (on black_block_1 red_block_1)) (hold_4)) (when (not (or (= ?obj white_block_2) (clear white_block_2))) (hold_5)) (when (and (not (or (= ?obj white_block_2) (clear white_block_2))) (not (or (not (or (= ?obj black_block_2) (clear black_block_2))) (and (holding white_block_1) (not (= ?obj white_block_1)))))) (not (hold_6))) (when (or (not (or (= ?obj black_block_2) (clear black_block_2))) (and (holding white_block_1) (not (= ?obj white_block_1)))) (hold_6)) (increase (total-cost) 1)))
 (:action stack
