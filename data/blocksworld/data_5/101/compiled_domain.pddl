  :precondition (and (clear ?obj) (ontable ?obj) (handempty) (or (and (ontable yellow_block_1) (not (= ?obj yellow_block_1))) (seen_psi_3)) (not (and (ontable white_block_1) (not (= ?obj white_block_1)))))
  :effect (and (holding ?obj) (not (clear ?obj)) (not (ontable ?obj)) (not (handempty)) (when (and (not (on yellow_block_1 grey_block_1)) (not (or (not (and (clear black_block_1) (not (= ?obj black_block_1)))) (not (and (clear white_block_1) (not (= ?obj white_block_1))))))) (not (hold_1))) (when (or (not (and (clear black_block_1) (not (= ?obj black_block_1)))) (not (and (clear white_block_1) (not (= ?obj white_block_1))))) (hold_1)) (when (not (and (ontable yellow_block_1) (not (= ?obj yellow_block_1)))) (hold_2)) (when (or (not (and (clear brown_block_1) (not (= ?obj brown_block_1)))) (not (and (ontable grey_block_1) (not (= ?obj grey_block_1))))) (seen_psi_3)) (when (not (and (ontable grey_block_1) (not (= ?obj grey_block_1)))) (hold_4)) (when (and (ontable yellow_block_1) (not (= ?obj yellow_block_1))) (hold_5)) (when (and (ontable yellow_block_1) (not (= ?obj yellow_block_1)) (not (or (= ?obj brown_block_1) (holding brown_block_1)))) (not (hold_6))) (when (or (= ?obj brown_block_1) (holding brown_block_1)) (hold_6)) (increase (total-cost) 1)))
 (:action putdown
  :parameters ( ?obj - block)
  :precondition (and (holding ?obj) (or (= ?obj yellow_block_1) (ontable yellow_block_1) (seen_psi_3)) (not (or (= ?obj white_block_1) (ontable white_block_1))))
  :effect (and (clear ?obj) (handempty) (ontable ?obj) (not (holding ?obj)) (when (and (not (on yellow_block_1 grey_block_1)) (not (or (not (or (= ?obj black_block_1) (clear black_block_1))) (not (or (= ?obj white_block_1) (clear white_block_1)))))) (not (hold_1))) (when (or (not (or (= ?obj black_block_1) (clear black_block_1))) (not (or (= ?obj white_block_1) (clear white_block_1)))) (hold_1)) (when (not (or (= ?obj yellow_block_1) (ontable yellow_block_1))) (hold_2)) (when (or (not (or (= ?obj brown_block_1) (clear brown_block_1))) (not (or (= ?obj grey_block_1) (ontable grey_block_1)))) (seen_psi_3)) (when (not (or (= ?obj grey_block_1) (ontable grey_block_1))) (hold_4)) (when (or (= ?obj yellow_block_1) (ontable yellow_block_1)) (hold_5)) (when (and (or (= ?obj yellow_block_1) (ontable yellow_block_1)) (not (and (holding brown_block_1) (not (= ?obj brown_block_1))))) (not (hold_6))) (when (and (holding brown_block_1) (not (= ?obj brown_block_1))) (hold_6)) (increase (total-cost) 1)))
 (:action stack
  :parameters ( ?obj - block ?underobj - block)
  :precondition (and (clear ?underobj) (holding ?obj))
  :effect (and (handempty) (clear ?obj) (on ?obj ?underobj) (not (clear ?underobj)) (not (holding ?obj)) (when (not (or (and (= ?obj yellow_block_1) (= ?underobj grey_block_1)) (on yellow_block_1 grey_block_1))) (hold_0)) (when (and (not (or (and (= ?obj yellow_block_1) (= ?underobj grey_block_1)) (on yellow_block_1 grey_block_1))) (not (or (not (or (= ?obj black_block_1) (and (clear black_block_1) (not (= ?underobj black_block_1))))) (not (or (= ?obj white_block_1) (and (clear white_block_1) (not (= ?underobj white_block_1)))))))) (not (hold_1))) (when (or (not (or (= ?obj black_block_1) (and (clear black_block_1) (not (= ?underobj black_block_1))))) (not (or (= ?obj white_block_1) (and (clear white_block_1) (not (= ?underobj white_block_1)))))) (hold_1)) (when (or (not (or (= ?obj brown_block_1) (and (clear brown_block_1) (not (= ?underobj brown_block_1))))) (not (ontable grey_block_1))) (seen_psi_3)) (when (and (ontable yellow_block_1) (not (and (holding brown_block_1) (not (= ?obj brown_block_1))))) (not (hold_6))) (when (and (holding brown_block_1) (not (= ?obj brown_block_1))) (hold_6)) (increase (total-cost) 1)))
 (:action unstack
  :parameters ( ?obj - block ?underobj - block)
  :precondition (and (on ?obj ?underobj) (clear ?obj) (handempty))
  :effect (and (holding ?obj) (clear ?underobj) (not (on ?obj ?underobj)) (not (clear ?obj)) (not (handempty)) (when (not (and (on yellow_block_1 grey_block_1) (not (and (= ?obj yellow_block_1) (= ?underobj grey_block_1))))) (hold_0)) (when (and (not (and (on yellow_block_1 grey_block_1) (not (and (= ?obj yellow_block_1) (= ?underobj grey_block_1))))) (not (or (not (or (= ?underobj black_block_1) (and (clear black_block_1) (not (= ?obj black_block_1))))) (not (or (= ?underobj white_block_1) (and (clear white_block_1) (not (= ?obj white_block_1)))))))) (not (hold_1))) (when (or (not (or (= ?underobj black_block_1) (and (clear black_block_1) (not (= ?obj black_block_1))))) (not (or (= ?underobj white_block_1) (and (clear white_block_1) (not (= ?obj white_block_1)))))) (hold_1)) (when (or (not (or (= ?underobj brown_block_1) (and (clear brown_block_1) (not (= ?obj brown_block_1))))) (not (ontable grey_block_1))) (seen_psi_3)) (when (and (ontable yellow_block_1) (not (or (= ?obj brown_block_1) (holding brown_block_1)))) (not (hold_6))) (when (or (= ?obj brown_block_1) (holding brown_block_1)) (hold_6)) (increase (total-cost) 1)))
)
